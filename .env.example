# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Your LeetCode session cookie value
# Get it from: Browser DevTools → Application → Cookies → leetcode.com → LEETCODE_SESSION
LEETCODE_SESSION=your_leetcode_session_cookie_here

# Your LeetCode CSRF token cookie value
# Get it from: Browser DevTools → Application → Cookies → leetcode.com → csrftoken
LEETCODE_CSRF=your_csrf_token_here
