# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Your LeetCode session cookie value
# Get it from: Browser DevTools → Application → Cookies → leetcode.com → LEETCODE_SESSION
LEETCODE_SESSION=your_leetcode_session_cookie_here

# Your LeetCode CSRF token cookie value
# Get it from: Browser DevTools → Application → Cookies → leetcode.com → csrftoken
LEETCODE_CSRF=your_csrf_token_here

# Your Groq API key
# Get it from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: Groq model id
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: number of questions fetched per random page window
QUESTION_SEARCH_LIMIT=50

# Optional: retry count if a selected question cannot be solved/submitted
MAX_RANDOM_TRIES=25

# Optional: include paid-only questions in random selection
INCLUDE_PAID_QUESTIONS=false
